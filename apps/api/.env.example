PORT=3002
DATABASE_URL="sqlserver://HOST:1433;database=DATABASE_NAME;user=USER;password=PASSWORD;encrypt=true;trustServerCertificate=true"
JWT_SECRET="cambiar-por-un-secret-largo"
JWT_EXPIRES_IN="8h"
CORS_ORIGIN="http://localhost:3000"
# Optional for prisma migrate dev on SQL Server when the main user cannot create databases:
